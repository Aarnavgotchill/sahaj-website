# Cloudflare R2 Public URL (required)
# This is used to serve all media assets (images, videos, audio, fonts)
VITE_R2_URL=https://assets.sahajgallery.com

# Cloudflare Account ID (optional, for wrangler deployment)
CLOUDFLARE_ACCOUNT_ID=

# R2 Bucket Name (optional, for asset upload scripts)
R2_BUCKET_NAME=sahaj-gallery-assets
